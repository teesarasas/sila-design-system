{
  "icon": {
    "size": {
      "xs": {
        "$type": "dimension",
        "$value": "{size.12px}",
        "$description": "12px - Extra small icons (inline with small text)"
      },
      "sm": {
        "$type": "dimension",
        "$value": "{size.16px}",
        "$description": "16px - Small icons (inline with body text)"
      },
      "md": {
        "$type": "dimension",

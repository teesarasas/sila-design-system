      "xl": {
        "$type": "dimension",
        "$value": "{size.32px}",
        "$description": "32px - Extra large icons (feature icons)"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "{size.40px}",
        "$description": "40px - 2x large icons (hero sections)"
      },
      "3xl": {
        "$type": "dimension",
        "$value": "{size.48px}",
        "$description": "48px - 3x large icons (illustrations)"

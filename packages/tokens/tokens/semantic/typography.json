{
  "typography": {
    "font-family": {
      "body": {
        "value": "{typography.font-family.sans}",
        "description": "Body text font family",
        "type": "fontFamily"
      },
      "heading": {
        "value": "{typography.font-family.sans}",
        "description": "Heading font family",
        "type": "fontFamily"
      },
      "code": {
        "value": "{typography.font-family.mono}",
        "description": "Code/monospace font family",
        "type": "fontFamily"
      }
    },
    "font-size": {
      "caption": {
        "value": "round( {typography.font-size.base} / ( {typography.typescale}^2)/2)*2",
        "type": "fontSizes",
        "description": "Caption/helper text size"
      },
      "body-sm": {
        "value": "round( {typography.font-size.base} / ( {typography.typescale}^1)/2)*2",
        "type": "fontSizes",
        "description": "Small body text size"
      },
      "body-md": {
        "value": "{typography.font-size.base}",
        "type": "fontSizes",
        "description": "Base body text size"
      },
      "body-lg": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^1)/2)*2",
        "type": "fontSizes",
        "description": "Large body text size"
      },
      "heading-sm": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^2)/2)*2",
        "type": "fontSizes",
        "description": "Small heading size"
      },
      "heading-md": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^4)/2)*2",
        "type": "fontSizes",
        "description": "Base heading size"
      },
      "heading-lg": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^6)/2)*2",
        "type": "fontSizes",
        "description": "Large heading size"
      },
      "heading-xl": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^8)/2)*2",
        "type": "fontSizes",
        "description": "Extra large heading size"
      },
      "display": {
        "value": "round( {typography.font-size.base} * ( {typography.typescale}^12)/2)*2",
        "type": "fontSizes",
        "description": "Display text size"
      }
    },
    "font-weight": {
      "body": {
        "value": "{typography.font-weight.regular}",
        "description": "Body text weight",
        "type": "fontWeights"
      },
      "body-strong": {
        "value": "{typography.font-weight.medium}",
        "description": "Emphasized body text weight",
        "type": "fontWeights"
      },
      "heading": {
        "value": "{typography.font-weight.semibold}",
        "description": "Heading weight",
        "type": "fontWeights"
      },
      "display": {
        "value": "{typography.font-weight.bold}",
        "description": "Display text weight",
        "type": "fontWeights"
      }
    },
    "line-height": {
      "caption": {
        "value": "round( {typography.line-height.normal} * {typography.font-size.caption}/2)*2",
        "type": "lineHeights",
        "description": "Body text line height"
      },
      "body-sm": {
        "value": "round( {typography.line-height.normal} * {typography.font-size.body-sm}/2)*2",
        "type": "lineHeights",
        "description": "Body text line height"
      },
      "body-md": {
        "value": "{typography.line-height.normal} * {typography.font-size.base}",
        "type": "lineHeights",
        "description": "Body text line height"
      },
      "body-lg": {
        "value": "round( {typography.line-height.normal} * {typography.font-size.body-lg}/2)*2",
        "type": "lineHeights",
        "description": "Body text line height"
      },
      "heading-sm": {
        "value": "round( {typography.line-height.tight} * {typography.font-size.heading-sm}/2)*2",
        "type": "lineHeights",
        "description": "Heading line height"
      },
      "heading-md": {
        "value": "round( {typography.line-height.tight} * {typography.font-size.heading-md}/2)*2",
        "type": "lineHeights",
        "description": "Heading line height"
      },
      "heading-lg": {
        "value": "round( {typography.line-height.tight} * {typography.font-size.heading-lg}/2)*2",
        "type": "lineHeights",
        "description": "Heading line height"
      },
      "heading-xl": {
        "value": "round( {typography.line-height.tight} * {typography.font-size.heading-xl}/2)*2",
        "type": "lineHeights",
        "description": "Heading line height"
      },
      "display": {
        "value": "round( {typography.line-height.tight} * {typography.font-size.display}/2)*2",
        "type": "lineHeights",
        "description": "Display text line height"
      }
    },
    "letter-spacing": {
      "body": {
        "value": "{typography.letter-spacing.normal}",
        "description": "Body text letter spacing",
        "type": "letterSpacing"
      },
      "heading": {
        "value": "{typography.letter-spacing.tight}",
        "description": "Heading letter spacing",
        "type": "letterSpacing"
      },
      "display": {
        "value": "{typography.letter-spacing.tighter}",
        "description": "Display text letter spacing",
        "type": "letterSpacing"
      }
    }
  }
}
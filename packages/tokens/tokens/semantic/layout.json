      },
      "dropdown": {
        "value": "{layout.zIndex.dropdown}",
        "description": "Dropdown menus and poppers",
        "type": "number"
      },
      "sticky": {
        "value": "{layout.zIndex.sticky}",
        "description": "Sticky headers and navigation bars",
        "type": "number"
      },
      "overlay": {
        "value": "{layout.zIndex.overlay}",
        "description": "Background overlays and backdrops",
        "type": "number"
      },
      "modal": {
        "value": "{layout.zIndex.modal}",
        "description": "Modal dialogs and drawers",
        "type": "number"
      },
      "toast": {
        "value": "{layout.zIndex.toast}",
        "description": "Toast notifications",
        "type": "number"
      },
      "tooltip": {
        "value": "{layout.zIndex.tooltip}",
        "description": "Tooltips — always rendered on top of everything",
        "type": "number"
      }
    }
  }

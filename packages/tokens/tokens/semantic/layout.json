{
  "layout": {
    "breakpoint": {
      "mobile": {
        "value": "{layout.breakpoint.mobile}",
        "description": "Mobile viewport — use as min-width in media queries",
        "type": "dimension"
      },
      "tablet": {
        "value": "{layout.breakpoint.tablet}",
        "description": "Tablet viewport — use as min-width in media queries",
        "type": "dimension"
      },
      "desktop": {
        "value": "{layout.breakpoint.desktop}",
        "description": "Desktop viewport — use as min-width in media queries",
        "type": "dimension"
      },
      "wide": {
        "value": "{layout.breakpoint.wide}",
        "description": "Wide viewport — for full-bleed backgrounds and decorative sections only, not content width",
        "type": "dimension"
      }
    },
    "container": {
      "maxWidth": {
        "value": "{layout.container.max}",
        "description": "Maximum content container width (1280px). Beyond this the container auto-centers with equal margins.",
        "type": "dimension"
      }
    },
    "grid": {
      "columns": {
        "mobile": {
          "value": "{layout.grid.columns.mobile}",
          "description": "4 columns on mobile — each column spans 25% of the viewport",
          "type": "number"
        },
        "tablet": {
          "value": "{layout.grid.columns.tablet}",
          "description": "8 columns on tablet — allows 2 and 4 column layouts",
          "type": "number"
        },
        "desktop": {
          "value": "{layout.grid.columns.desktop}",
          "description": "12 columns on desktop — allows 2, 3, 4, and 6 column layouts",
          "type": "number"
        }
      },
      "gutter": {
        "mobile": {
          "value": "{spacing.16px}",
          "description": "Gap between grid columns on mobile",
          "type": "dimension"
        },
        "tablet": {
          "value": "{spacing.24px}",
          "description": "Gap between grid columns on tablet",
          "type": "dimension"
        },
        "desktop": {
          "value": "{spacing.32px}",
          "description": "Gap between grid columns on desktop",
          "type": "dimension"
        }
      },
      "margin": {
        "mobile": {
          "value": "{spacing.16px}",
          "description": "Fixed page-edge margin on mobile — provides breathing room from screen edges",
          "type": "dimension"
        },
        "tablet": {
          "value": "{spacing.32px}",
          "description": "Fixed page-edge margin on tablet",
          "type": "dimension"
        },
        "desktop": {
          "value": "{spacing.48px}",
          "description": "Fixed page-edge margin on desktop. Once the container hits layout.container.maxWidth it auto-centers instead.",
          "type": "dimension"
        }
      }
    },
    "gap": {
      "xs": {
        "value": "{spacing.4px}",
        "description": "Extra small gap — tight inline groupings",
        "type": "dimension"
      },
      "sm": {
        "value": "{spacing.8px}",
        "description": "Small gap — compact lists and stacks",
        "type": "dimension"
      },
      "md": {
        "value": "{spacing.12px}",
        "description": "Medium gap — default flex/grid gap",
        "type": "dimension"
      },
      "lg": {
        "value": "{spacing.16px}",
        "description": "Large gap — comfortable content groupings",
        "type": "dimension"
      },
      "xl": {
        "value": "{spacing.24px}",
        "description": "Extra large gap — spacious layouts",
        "type": "dimension"
      },
      "2xl": {
        "value": "{spacing.32px}",
        "description": "2x large gap — distinct content blocks",
        "type": "dimension"
      },
      "3xl": {
        "value": "{spacing.48px}",
        "description": "3x large gap — major layout divisions",
        "type": "dimension"
      }
    },
    "padding": {
      "inline": {
        "xs": {
          "value": "{spacing.4px}",
          "description": "Extra small horizontal padding",
          "type": "dimension"
        },
        "sm": {
          "value": "{spacing.8px}",
          "description": "Small horizontal padding",
          "type": "dimension"
        },
        "md": {
          "value": "{spacing.12px}",
          "description": "Medium horizontal padding",
          "type": "dimension"
        },
        "lg": {
          "value": "{spacing.16px}",
          "description": "Large horizontal padding",
          "type": "dimension"
        },
        "xl": {
          "value": "{spacing.24px}",
          "description": "Extra large horizontal padding",
          "type": "dimension"
        }
      },
      "stack": {
        "xs": {
          "value": "{spacing.4px}",
          "description": "Extra small vertical padding",
          "type": "dimension"
        },
        "sm": {
          "value": "{spacing.8px}",
          "description": "Small vertical padding",
          "type": "dimension"
        },
        "md": {
          "value": "{spacing.12px}",
          "description": "Medium vertical padding",
          "type": "dimension"
        },
        "lg": {
          "value": "{spacing.16px}",
          "description": "Large vertical padding",
          "type": "dimension"
        },
        "xl": {
          "value": "{spacing.24px}",
          "description": "Extra large vertical padding",
          "type": "dimension"
        }
      },
      "section": {
        "sm": {
          "value": "{spacing.48px}",
          "description": "Compact section vertical padding — dense content pages",
          "type": "dimension"
        },
        "md": {
          "value": "{spacing.64px}",
          "description": "Standard section vertical padding — most page sections",
          "type": "dimension"
        },
        "lg": {
          "value": "{spacing.96px}",
          "description": "Spacious section vertical padding — hero sections and major page breaks",
          "type": "dimension"
        }
      }

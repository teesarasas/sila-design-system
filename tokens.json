  "semantic/spacing": {
    "layout": {
      "space-3xs": {
        "value": "round( {base.font-size} * {base.multiplier.100} /4)*4",
        "type": "spacing"
      },
      "space-2xs": {
        "value": "round( {base.font-size} * {base.multiplier.200} /4)*4",
        "type": "spacing"

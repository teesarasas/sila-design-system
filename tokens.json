{
  "global/mobile/base-size": {
    "base": {
      "font-size": {
        "value": "14",
        "type": "number",
        "description": "Used as a base size for the mobile view."
      },
      "type-scale": {
        "value": "1.2",
        "type": "number",
        "description": "Minor third scale"
      }
    }
  },
  "global/desktop/base-size": {
    "base": {
      "font-size": {
        "value": "16",
        "type": "number",
        "description": "Used as a base size for the desktop view."
      },
      "type-scale": {
        "value": "1.25",
        "type": "number",
        "description": "Major third scale"
      }
    }
  },
  "global/typography": {
    "Geist": {
      "value": "Geist",
      "type": "fontFamilies"
    },
    "Geist Mono": {
      "value": "Geist Mono",
      "type": "fontFamilies"
    },
    "base": {
      "line-height-ratio": {
        "text": {
          "value": "1.5",
          "type": "lineHeights",
          "description": "Use this line height ratio to calculate the text, paragraph line height."
        },
        "headline": {
          "value": "1.1",
          "type": "lineHeights",
          "description": "Use this line height ratio to calculate the headline line height."
        }
      }
    }
  },
  "global/multiplier": {
    "100": {
      "value": "0.25",
      "type": "number"
    },
    "200": {
      "value": "0.5",
      "type": "number"
    },
    "300": {
      "value": "0.75",
      "type": "number"
    },
    "400": {
      "value": 1,
      "type": "number"
    },
    "500": {
      "value": 1.5,
      "type": "number"
    },
    "600": {
      "value": 2,
      "type": "number"
    },
    "700": {
      "value": 3,
      "type": "number"
    },
    "800": {
      "value": 4,
      "type": "number"
    },
    "900": {
      "value": 6,
      "type": "number"
    }
  },
  "semantic/spacing": {
    "space-3xs": {
      "value": "round( {base.font-size} * {100} /4)*4",
      "type": "spacing"
    },
    "space-2xs": {
      "value": "round( {base.font-size} * {200} /4)*4",
      "type": "spacing"
    },
    "space-xs": {
      "value": "round( {base.font-size} * {300} /4)*4",
      "type": "spacing"
    },
    "space-s": {
      "value": "round( {base.font-size} * {400} /4)*4",
      "type": "spacing"
    },
    "space-m": {
      "value": "round( {base.font-size} * {500} /4)*4",
      "type": "spacing"
    },
    "space-l": {
      "value": "round( {base.font-size} * {600} /4)*4",
      "type": "spacing"
    },
    "space-xl": {
      "value": "round( {base.font-size} * {700} /4)*4",
      "type": "spacing"
    },
    "space-2xl": {
      "value": "round( {base.font-size} * {800} /4)*4",
      "type": "spacing"
    },
    "space-3xl": {
      "value": "round( {base.font-size} * {900} /4)*4",
      "type": "spacing"
    }
  },
  "semantic/typography": {
    "semantic": {
      "text": {
        "text-sm-regular": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Regular",
            "lineHeight": "{semantic.line-height.text.sm}",
            "fontSize": "{semantic.font-size.text.sm}"
          },
          "type": "typography",
          "description": "Secondary text. Use for metadata (timestamps, authors), footnotes, helper text below inputs, or legal disclaimers. Do NOT use for main content essential to the user journey (readability concerns)."
        },
        "text-base-regular": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Regular",
            "fontSize": "{base.font-size}",
            "lineHeight": "{semantic.line-height.text.base}"
          },
          "type": "typography",
          "description": "The DEFAULT token for all standard content. Use for paragraphs, lists (ul/ol), and general reading. If no specific size is required, MUST default to this token. Optimized for long-form reading comfort."
        },
        "text-lg-regular": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Regular",
            "fontSize": "{semantic.font-size.text.lg}",
            "lineHeight": "{semantic.line-height.text.lg}"
          },
          "type": "typography",
          "description": "Lead paragraph or introductory text. Use this ONLY for the first paragraph of a section, abstract summaries, or emphasized text blocks. Do NOT use for long-form content as it consumes too much vertical space."
        }
      },
      "headline": {
        "h6": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h6}",
            "lineHeight": "{semantic.line-height.headline.h6}"
          },
          "type": "typography",
          "description": "Level 6 Heading. The lowest section level. Used for low-level labels or titles within an H5. MUST strictly follow H5."
        },
        "h5": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h5}",
            "lineHeight": "{semantic.line-height.headline.h5}"
          },
          "type": "typography",
          "description": "Level 5 Heading. Used for detailed groups within an H4. MUST strictly follow H4."
        },
        "h4": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h4}",
            "lineHeight": "{semantic.line-height.headline.h4}"
          },
          "type": "typography",
          "description": "Level 4 Heading. Used for nested topics within an H3 block. MUST strictly follow H3. Do NOT use H4 directly after H2."
        },
        "h3": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h3}",
            "lineHeight": "{semantic.line-height.headline.h3}"
          },
          "type": "typography",
          "description": "Level 3 Heading. Used for subsections within an H2 block. MUST NOT appear unless nested under an H2. Do NOT use H3 directly after H1 (skipping H2 is a WCAG violation)."
        },
        "h2": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h2}",
            "lineHeight": "{semantic.line-height.headline.h2}"
          },
          "type": "typography",
          "description": "Level 2 Heading. Used for major sections within the page. MUST follow an H1 or be the start of a major section. Do NOT skip from H1 to H3. Acts as a container for H3 content."
        },
        "h1": {
          "value": {
            "fontFamily": "{Geist}",
            "fontWeight": "Bold",
            "fontSize": "{semantic.font-size.heading.h1}",
            "lineHeight": "{semantic.line-height.headline.h1}"
          },
          "type": "typography",
          "description": "Level 1 Heading. MUST serve as the unique page title. There MUST be exactly one H1 per page. Do NOT use for decorative text; use it solely for the main topic of the page."
        }
      },
      "font-size": {
        "text": {
          "sm": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, -1))/2)*2",
            "type": "fontSizes"
          },
          "base": {
            "value": "{base.font-size}",
            "type": "fontSizes"
          },
          "lg": {
            "value": "round(({base.font-size}*pow({base.type-scale},1))/2)*2",
            "type": "fontSizes"
          }
        },
        "heading": {
          "h6": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 2))/2)*2",
            "type": "fontSizes"
          },
          "h5": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 3))/2)*2",
            "type": "fontSizes"
          },
          "h4": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 4))/2)*2",
            "type": "fontSizes"
          },
          "h3": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 5))/2)*2",
            "type": "fontSizes"
          },
          "h2": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 6))/2)*2",
            "type": "fontSizes"
          },
          "h1": {
            "value": "round(( {base.font-size} * pow({base.type-scale}, 7))/2)*2",
            "type": "fontSizes"
          }
        }
      },
      "line-height": {
        "text": {
          "sm": {
            "value": "round( {semantic.font-size.text.sm}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "base": {
            "value": "round( {semantic.font-size.text.base}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "lg": {
            "value": "round( {semantic.font-size.text.lg}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          }
        },
        "headline": {
          "h6": {
            "value": "round( {semantic.font-size.heading.h6}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "h5": {
            "value": "round( {semantic.font-size.heading.h5}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "h4": {
            "value": "round( {semantic.font-size.heading.h4}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "h3": {
            "value": "round( {semantic.font-size.heading.h3}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "h2": {
            "value": "round( {semantic.font-size.heading.h2}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          },
          "h1": {
            "value": "round( {semantic.font-size.heading.h1}  * {base.line-height-ratio.text} /4)*4",
            "type": "lineHeights"
          }
        }
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "global/mobile/base-size",
      "global/desktop/base-size",
      "global/typography",
      "global/multiplier",
      "semantic/spacing",
      "semantic/typography"
    ]
  }
}